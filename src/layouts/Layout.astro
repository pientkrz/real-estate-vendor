---
import '../index.css';

interface Props {
	title: string;
	description?: string;
	lockViewport?: boolean;
}

const { title, description = "Global S Home - Premium Real Estate", lockViewport = false } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Material Symbols (self-hosted) -->
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}fonts/material-symbols.css`} />
	</head>
	<body class={`bg-surface font-body text-on-surface selection:bg-primary-container selection:text-on-primary-container ${lockViewport ? 'overflow-hidden' : 'min-h-screen'}`}>
		<slot />
	</body>
</html>
