---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { parseOffersXml } from '../../utils/xmlParser';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
    const xmlPath = path.join(process.cwd(), 'public', 'offers.xml');
    const xmlString = fs.readFileSync(xmlPath, 'utf-8');
    const allOffers = parseOffersXml(xmlString);
    
    return allOffers.map(offer => ({
        params: { id: offer.id },
        props: { offer }
    }));
}

const { offer } = Astro.props;
const { params, location, price, currency } = offer;

const formattedPrice = `${currency === 'EUR' ? '€' : currency}${ (price / 1000000).toFixed(1) }M`;
const image = params?.zdjecie1 || '/assets/placeholder.jpg';
---

<Layout title={`${params?.miasto || 'Property Detail'} | Global S Home`} description={params?.opis?.substring(0, 160)}>
	<Navbar client:load />
	
	<main class="pt-32 pb-24">
		<article class="max-w-7xl mx-auto px-6 md:px-12">
			<!-- Hero Section for Property -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-24 items-center">
				<div class="animate-in fade-in slide-in-from-left-4 duration-1000">
					<span class="text-primary font-label text-sm tracking-[0.3em] uppercase mb-6 block">
						{offer.typ === 'sprzedaz' ? 'Premium Listing' : 'Luxury Rental'}
					</span>
					<h1 class="text-6xl md:text-7xl font-headline font-bold mb-8 leading-[1.1] tracking-tight">
						{params?.miasto || 'The Architectural Estate'}
					</h1>
					<p class="text-xl text-on-surface-variant font-body mb-12 leading-relaxed max-w-xl">
						{location?.level2}, {location?.level1} — A masterclass in modern Mediterranean design, offering unparalleled privacy and tonal depth.
					</p>
					
					<div class="flex flex-wrap gap-12 mb-12">
						<div>
							<span class="block text-[10px] uppercase tracking-widest text-outline mb-2">Investment</span>
							<span class="text-3xl font-headline font-bold text-primary">{formattedPrice}</span>
						</div>
						<div>
							<span class="block text-[10px] uppercase tracking-widest text-outline mb-2">Total area</span>
							<span class="text-3xl font-headline font-bold">{params?.powierzchnia}m²</span>
						</div>
					</div>

					<button class="editorial-gradient px-10 py-5 rounded-sm text-on-primary font-label uppercase tracking-widest text-[12px] shadow-2xl hover:scale-105 transition-transform active:scale-95">
						Inquire via Collector
					</button>
				</div>
				
				<div class="relative aspect-[4/5] overflow-hidden rounded-sm animate-in fade-in slide-in-from-right-4 duration-1000 shadow-[0_48px_80px_-16px_rgba(0,0,0,0.3)]">
					<img src={image} alt="Property Image" class="w-full h-full object-cover" />
					<div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
				</div>
			</div>

			<!-- Details Grid -->
			<div class="bg-surface-container-low p-12 md:p-16 rounded-sm mb-24 grid grid-cols-2 md:grid-cols-4 gap-12">
				<div>
					<span class="block font-label text-[10px] uppercase tracking-widest text-outline mb-4">Bedrooms</span>
					<div class="flex items-center gap-4">
						<span class="material-symbols-outlined text-primary">bed</span>
						<span class="text-2xl font-headline font-semibold">{params?.liczbapokoi}</span>
					</div>
				</div>
				<div>
					<span class="block font-label text-[10px] uppercase tracking-widest text-outline mb-4">Bathrooms</span>
					<div class="flex items-center gap-4">
						<span class="material-symbols-outlined text-primary">shower</span>
						<span class="text-2xl font-headline font-semibold">{params?.liczbalazienek}</span>
					</div>
				</div>
				<div>
					<span class="block font-label text-[10px] uppercase tracking-widest text-outline mb-4">Pool</span>
					<div class="flex items-center gap-4">
						<span class="material-symbols-outlined text-primary">pool</span>
						<span class="text-2xl font-headline font-semibold">Yes</span>
					</div>
				</div>
				<div>
					<span class="block font-label text-[10px] uppercase tracking-widest text-outline mb-4">Year Built</span>
					<div class="flex items-center gap-4">
						<span class="material-symbols-outlined text-primary">calendar_today</span>
						<span class="text-2xl font-headline font-semibold">2024</span>
					</div>
				</div>
			</div>

			<!-- Description -->
			<div class="max-w-3xl mx-auto mb-24">
				<h2 class="text-3xl font-headline font-bold mb-8">Architectural Narrative</h2>
				<div class="text-lg text-on-surface-variant leading-loose font-body space-y-6">
					{params?.opis && <div dangerouslySetInnerHTML={{ __html: params.opis }} />}
				</div>
			</div>
		</article>
	</main>
	
	<Footer />
</Layout>
