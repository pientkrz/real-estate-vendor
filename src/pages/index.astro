---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import CollectionManager from '../components/CollectionManager';
import { parseOtoDomXml } from '../utils/xmlParser';
import { FALLBACK_RATES } from '../utils/exchangeRates';
import fs from 'node:fs';
import path from 'node:path';

const xmlPath = import.meta.env.OFFERS_XML_PATH
  ?? path.join(process.cwd(), 'public', import.meta.env.XML_COLLECTION_PATH ?? '', 'properties_otodom.xml');

const xmlString = fs.readFileSync(xmlPath, 'utf-8');
const photoBase = import.meta.env.PHOTO_BASE_URL;
const allOffers = parseOtoDomXml(xmlString, photoBase);
---

<Layout title="Global S Home | Premium Real Estate">
	<Navbar client:load />
	<CollectionManager
		client:load
		initialOffers={allOffers}
		initialRates={FALLBACK_RATES}
		initialRatesTimestamp={null}
	/>
</Layout>
