---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import CollectionManager from '../components/CollectionManager';
import { parseOtoDomXml } from '../utils/xmlParser';
import { getRates } from '../server/rateService';
import fs from 'node:fs';
import path from 'node:path';

const xmlPath = path.join(process.cwd(), 'public', import.meta.env.XML_COLLECTION_PATH, 'properties_otodom.xml');
const xmlString = fs.readFileSync(xmlPath, 'utf-8');
const photoBase = import.meta.env.PHOTO_BASE_URL;
const allOffers = parseOtoDomXml(xmlString, photoBase);
const { rates } = getRates();
---

<Layout title="Global S Home | Premium Real Estate">
	<Navbar client:load />
	<CollectionManager client:only="react" initialOffers={allOffers} initialRates={rates} />
</Layout>
