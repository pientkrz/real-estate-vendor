---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ContactForm from '../components/ContactForm';
---

<Layout title="Contact Us | Local T P - Premium Real Estate">
	<Navbar client:load />
	
	<main class="bg-background min-h-screen pt-24 pb-16">
		{/* Hero Section for Contact */}
		<section class="w-full relative py-20 md:py-32 overflow-hidden flex items-center justify-center">
			{/* Abstract background element */}
			<div class="absolute inset-0 opacity-10 pointer-events-none">
				<div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full border border-primary/30 translate-x-1/2 -translate-y-1/4"></div>
				<div class="absolute bottom-0 left-0 w-[800px] h-[800px] rounded-full border border-primary/20 -translate-x-1/3 translate-y-1/3"></div>
			</div>
			
			<div class="relative z-10 px-6 max-w-4xl mx-auto text-center">
				<h1 class="text-5xl md:text-7xl font-headline font-bold text-on-surface tracking-tighter mb-6">
					Connect With <br class="hidden md:block"/> Our Atelier
				</h1>
				<p class="text-on-surface-variant font-body text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed">
					Whether acquiring an architectural masterpiece or entrusting us with your legacy estate, our curators are at your absolute disposal.
				</p>
			</div>
		</section>

		{/* Contact Content Area */}
		<section class="max-w-7xl mx-auto px-6 md:px-12 py-12 grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
			
			{/* Contact Information */}
			<div class="lg:col-span-5 space-y-12">
				<div>
					<h3 class="text-xs font-label uppercase tracking-[0.2em] text-primary mb-4">Headquarters</h3>
					<p class="text-on-surface font-body text-lg">
						128 Architettura Avenue<br/>
						Design District<br/>
						Milan, 20121, Italy
					</p>
				</div>
				
				<div>
					<h3 class="text-xs font-label uppercase tracking-[0.2em] text-primary mb-4">Direct Lines</h3>
					<div class="space-y-2">
						<p class="text-on-surface font-body flex items-center gap-3">
							<span class="material-symbols-outlined text-outline">call</span>
							<a href="tel:+390212345678" class="hover:text-primary transition-colors">+39 02 1234 5678</a>
						</p>
						<p class="text-on-surface font-body flex items-center gap-3">
							<span class="material-symbols-outlined text-outline">mail</span>
							<a href="mailto:concierge@localtp.com" class="hover:text-primary transition-colors">concierge@localtp.com</a>
						</p>
					</div>
				</div>

				<div>
					<h3 class="text-xs font-label uppercase tracking-[0.2em] text-primary mb-4">Office Hours</h3>
					<p class="text-on-surface font-body">
						Monday – Friday: 10:00 – 18:00 (CET)<br/>
						<span class="text-sm text-on-surface-variant mt-2 block">Private viewings available globally by appointment.</span>
					</p>
				</div>
			</div>

			{/* Form Container */}
			<div class="lg:col-span-7 w-full relative z-20">
				<ContactForm client:load />
			</div>
			
		</section>
	</main>

	<Footer />
</Layout>
