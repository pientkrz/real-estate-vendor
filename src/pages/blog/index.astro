---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { getCollection } from 'astro:content';

const blogEntries = await getCollection('blog');
---

<Layout title="Journal - Global S Home">
	<Navbar client:load />
	<main class="pt-32 pb-24 px-12 max-w-screen-2xl mx-auto">
		<header class="mb-20">
			<span class="text-primary font-label text-sm tracking-[0.2em] uppercase mb-4 block">The Journal</span>
			<h1 class="text-6xl font-headline font-bold text-stone-900 leading-tight max-w-4xl">
				Editorial Insights on Mediterranean Living & Architecture.
			</h1>
		</header>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16">
			{blogEntries.map(entry => (
				<article class="group cursor-pointer">
					<a href={`/blog/${entry.id}`} class="block">
						<div class="aspect-[4/5] overflow-hidden rounded-sm mb-6 bg-stone-200">
							{entry.data.image ? (
								<img 
									src={entry.data.image} 
									alt={entry.data.title}
									class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
								/>
							) : (
								<div class="w-full h-full editorial-gradient opacity-20" />
							)}
						</div>
						<div class="space-y-4">
							<div class="flex items-center gap-4 text-xs font-label tracking-widest uppercase text-stone-500">
								<span>{entry.data.date?.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
								<span class="w-1 h-1 bg-stone-300 rounded-full"></span>
								<span>{entry.data.author || 'Editorial Staff'}</span>
							</div>
							<h2 class="text-2xl font-headline font-bold text-stone-900 group-hover:text-amber-800 transition-colors leading-tight">
								{entry.data.title}
							</h2>
							<p class="text-stone-500 line-clamp-3 leading-relaxed font-body">
								{entry.data.description}
							</p>
							<div class="pt-4 inline-flex items-center gap-2 text-stone-900 font-semibold group-hover:gap-4 transition-all">
								<span>Read Article</span>
								<span class="material-symbols-outlined text-sm">arrow_forward</span>
							</div>
						</div>
					</a>
				</article>
			))}
		</div>

		{blogEntries.length === 0 && (
			<div class="py-20 text-center border-t border-stone-200">
				<p class="text-stone-500 font-label italic">Our editorial vault is currently quiet. Please check back soon.</p>
			</div>
		)}
	</main>
	<Footer />
</Layout>

<style>
	@reference "../../index.css";
</style>
