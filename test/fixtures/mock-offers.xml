      <Action>1</Action>
      <ObjectName>0</ObjectName>
      <OfferType>0</OfferType>
      <Price>100000</Price>
      <PriceCurrency>2</PriceCurrency>
      <Area>50</Area>
      <Title>Deactivated Offer</Title>
