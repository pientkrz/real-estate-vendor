<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mock Otodom XML export for tests.

  6 active offers (2 per country: Spain, Greece, Cyprus) + 1 inactive offer
  that must be excluded by the parser (Action=1).

  Coordinates are chosen so the reverseGeocode stub in CollectionManager.test.jsx
  can distinguish countries purely from longitude:
    lon < -3          → Madrid,       Spain
    lon ∈ [-3, 0)     → Barcelona,    Spain
    lon ∈ [20, 23)    → Thessaloniki, Greece
    lon ∈ [23, 27)    → Athens,       Greece
    lon ∈ [27, 32.5)  → Paphos,       Cyprus
    lon ≥ 32.5        → Limassol,     Cyprus
-->
<otoDom>
  <Insertions>

    <!-- ── Spain ────────────────────────────────────────────────────────── -->
    <Insertion>
      <ID>sp1</ID>
      <Action>0</Action>
      <ObjectName>0</ObjectName>
      <OfferType>0</OfferType>
      <Price>250000</Price>
      <PriceCurrency>2</PriceCurrency>
      <Area>80</Area>
      <Title>Madrid Apartment</Title>
      <Description>Spacious flat in the heart of Madrid.</Description>
      <GeoMarker>
        <Latitude>40.4168</Latitude>
        <Longitude>-3.7038</Longitude>
      </GeoMarker>
      <FlatDetails>
        <RoomsNum>3</RoomsNum>
      </FlatDetails>
    </Insertion>

    <Insertion>
      <ID>sp2</ID>
      <Action>0</Action>
      <ObjectName>0</ObjectName>
      <OfferType>0</OfferType>
      <Price>180000</Price>
      <PriceCurrency>2</PriceCurrency>
      <Area>55</Area>
      <Title>Barcelona Studio</Title>
      <Description>Modern studio near Sagrada Familia.</Description>
      <GeoMarker>
        <Latitude>41.3851</Latitude>
        <Longitude>-2.1734</Longitude>
      </GeoMarker>
      <FlatDetails>
        <RoomsNum>1</RoomsNum>
      </FlatDetails>
    </Insertion>

    <!-- ── Greece ───────────────────────────────────────────────────────── -->
    <Insertion>
      <ID>gr1</ID>
