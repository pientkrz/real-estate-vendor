      <GeoMarker>
        <Latitude>37.9755</Latitude>
        <Longitude>23.7348</Longitude>
      </GeoMarker>
      <FlatDetails>
        <RoomsNum>4</RoomsNum>
      </FlatDetails>
    </Insertion>

    <Insertion>
      <ID>gr2</ID>
      <Action>0</Action>
      <ObjectName>0</ObjectName>
      <OfferType>0</OfferType>
      <Price>270000</Price>
      <PriceCurrency>2</PriceCurrency>
      <Area>75</Area>
      <Title>Thessaloniki Flat</Title>
      <Description>Sea-view flat in the White Tower district.</Description>
      <GeoMarker>
        <Latitude>40.6401</Latitude>
        <Longitude>22.9444</Longitude>
      </GeoMarker>
      <FlatDetails>
        <RoomsNum>2</RoomsNum>
      </FlatDetails>
    </Insertion>

    <!-- ── Cyprus ───────────────────────────────────────────────────────── -->
    <Insertion>
      <ID>cy1</ID>
      <Action>0</Action>
      <ObjectName>0</ObjectName>
      <OfferType>0</OfferType>
      <Price>450000</Price>
      <PriceCurrency>2</PriceCurrency>
      <Area>120</Area>
      <Title>Limassol Penthouse</Title>
      <Description>Luxury penthouse with sea views.</Description>
      <GeoMarker>
        <Latitude>34.6751</Latitude>
