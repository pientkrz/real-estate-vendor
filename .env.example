# Timestamped folder inside public/ that contains the Otodom XML export and photos.
# Must match the folder name exactly, including URL-encoded characters.
# Example: 2026-05-23_13%3A07%3A04
XML_COLLECTION_PATH='2026-05-23_13%3A07%3A04'

# Directory containing blog Markdown files, relative to the project root.
# Defaults to ./src/content/blog if not set.
BLOG_CONTENT_PATH='./src/content/blog'

# Directory containing the privacy policy Markdown file, relative to the project root.
PRIVACY_POLICY_CONTENT_PATH='./src/content/privacy-policy'

# Path to the JSON file containing the list of broker agents.
AGENTS_FILE_PATH='./src/data/agents.json'

# URL prefix for listing photos.
# If not set, falls back to the local public/ folder (useful during development
# when you have the images checked out locally).
#
# For production set this to the base URL + collection path:
#   https://pientkrz.github.io/real-estate-vendor/2026-05-23_13%3A07%3A04/
PHOTO_BASE_URL=
